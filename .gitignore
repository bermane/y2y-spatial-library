# --- Canonical data (tracked via inventory, not git) ---
library/**
!library/
!library/**/
!library/**/.gitkeep
!library/README.md

# --- Queue working directories ---
queue/incoming/**
!queue/incoming/
!queue/incoming/.gitkeep
queue/processing/**
!queue/processing/
!queue/processing/.gitkeep
queue/rejected/**
!queue/rejected/
!queue/rejected/.gitkeep
queue/archived/**
!queue/archived/
!queue/archived/.gitkeep

# --- Generated artifacts ---
# inventory.xlsx is a regenerated read-only view of inventory.db
# (post-migration 001); never the source of truth.
inventory/inventory.xlsx
# SQLite catalogue + WAL/SHM siblings — source of truth, not in git.
inventory/inventory.db
inventory/inventory.db-wal
inventory/inventory.db-shm
# Pre-migration xlsx backup — local-only audit; v0.1-xlsx git tag is
# the canonical pre-migration snapshot.
inventory/inventory.xlsx.pre-migration-backup
# Excel temp lock files (created when an .xlsx is open)
**/~$*.xlsx
reports/**
!reports/
!reports/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# --- OS cruft ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
.parallels-*
*.lnk

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
